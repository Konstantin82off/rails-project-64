- if user_signed_in?
  - if post.liked_by?(current_user)
    = button_to post_like_path(post, current_user.likes.find_by(post: post)), 
        method: :delete, 
        class: 'btn btn-sm btn-link p-0 text-decoration-none text-muted border-0' do
      span.small = "Понравилось: #{post.likes.count}"
  - else
    = button_to post_likes_path(post), 
        method: :post, 
        class: 'btn btn-sm btn-link p-0 text-decoration-none text-muted border-0' do
      span.small = "Понравилось: #{post.likes.count}"
- else
  span.text-muted.small
    = "Понравилось: #{post.likes.count}"
    